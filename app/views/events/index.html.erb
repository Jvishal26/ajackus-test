<h1>Events</h1>

<% if @events.empty? %>
  <p>No events found.</p>
<% else %>
  <% @events.each do |event| %>
    <% vote_count = @vote_counts[event.billetto_id] %>
    <div>
      <h2><%= event.title %></h2>

      <% if event.image_url.present? %>
        <img src="<%= event.image_url %>" alt="<%= event.title %>" width="200" />
      <% end %>

      <p>
        <strong>Date:</strong>
        <%= event.starts_at&.strftime("%d %b %Y, %H:%M") %>
        <% if event.ends_at.present? %>&ndash; <%= event.ends_at.strftime("%H:%M") %><% end %>
      </p>

      <% if event.city.present? %>
        <p><strong>Location:</strong> <%= [event.location_name, event.city, event.country].compact.join(", ") %></p>
      <% end %>

      <% if event.description.present? %>
        <p><%= truncate(event.description, length: 200) %></p>
      <% end %>

      <% if event.url.present? %>
        <p><a href="<%= event.url %>" target="_blank" rel="noopener">View on Billetto</a></p>
      <% end %>

      <p>
        Votes: &uarr; <%= vote_count&.upvotes || 0 %> &darr; <%= vote_count&.downvotes || 0 %>
        &nbsp;
        <% if signed_in? %>
          <%= button_to "Upvote",   votes_path(event_id: event.billetto_id, kind: "up"),   method: :post %>
          <%= button_to "Downvote", votes_path(event_id: event.billetto_id, kind: "down"), method: :post %>
        <% else %>
          <%= link_to "Sign in to vote", sign_in_path %>
        <% end %>
      </p>
    </div>
    <hr>
  <% end %>

  <p>
    Page <%= @page %> of <%= @total_pages %>
    &nbsp;
    <% if @page > 1 %>
      <%= link_to "Previous", events_path(page: @page - 1) %>
    <% end %>
    <% if @page < @total_pages %>
      <%= link_to "Next", events_path(page: @page + 1) %>
    <% end %>
  </p>
<% end %>
