<h1>Events</h1>

<% if notice.present? %>
  <p style="color: green;"><%= notice %></p>
<% end %>
<% if alert.present? %>
  <p style="color: red;"><%= alert %></p>
<% end %>

<% if @events.empty? %>
  <p>No events found.</p>
<% else %>
  <% @events.each do |event| %>
    <% vote_count = @vote_counts[event.billetto_id] %>
    <div style="border: 1px solid #ccc; margin-bottom: 1.5em; padding: 1em;">
      <% if event.image_url.present? %>
        <img src="<%= event.image_url %>" alt="<%= event.title %>" style="max-width: 180px; float: right; margin-left: 1em;" />
      <% end %>

      <h2><%= event.title %></h2>

      <p>
        <strong>When:</strong>
        <%= event.starts_at&.strftime("%d %b %Y, %H:%M") %>
        <% if event.ends_at.present? %>
          &ndash; <%= event.ends_at.strftime("%H:%M") %>
        <% end %>
      </p>

      <% if event.location_name.present? || event.city.present? %>
        <p>
          <strong>Where:</strong>
          <%= [event.location_name, event.city, event.country].compact.join(", ") %>
        </p>
      <% end %>

      <% if event.description.present? %>
        <p><%= truncate(event.description, length: 200) %></p>
      <% end %>

      <% if event.url.present? %>
        <p><a href="<%= event.url %>" target="_blank" rel="noopener">View on Billetto &rarr;</a></p>
      <% end %>

      <div style="margin-top: 0.75em;">
        <strong>Votes:</strong>
        &uarr; <%= vote_count&.upvotes || 0 %>
        &darr; <%= vote_count&.downvotes || 0 %>

        <% if user_signed_in? %>
          &nbsp;
          <%= button_to "👍 Upvote", votes_path(event_id: event.billetto_id, kind: "up"), method: :post %>
          <%= button_to "👎 Downvote", votes_path(event_id: event.billetto_id, kind: "down"), method: :post %>
        <% else %>
          <em style="margin-left: 0.5em;">(Sign in to vote)</em>
        <% end %>
      </div>

      <div style="clear: both;"></div>
    </div>
  <% end %>
<% end %>
