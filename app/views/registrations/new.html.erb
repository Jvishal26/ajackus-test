<% content_for :title, "Sign up – Billetto" %>

<style>
  .auth-page { display: flex; flex-direction: column; align-items: center; padding-top: 2rem; }
  .auth-page h1 { font-size: 1.5rem; font-weight: 600; margin-bottom: 0.5rem; }
  .auth-page p  { color: #666; font-size: 0.9rem; margin-bottom: 2rem; }
  #clerk-sign-up { min-height: 500px; }
</style>

<div class="auth-page">
  <h1>Create an account</h1>
  <p>Sign up to browse and vote on Billetto events</p>
  <div id="clerk-sign-up"></div>
</div>

<script>
  (function () {
    function mountSignUp() {
      Clerk.mountSignUp(document.getElementById("clerk-sign-up"), {
        routing: "hash",
        signInUrl: "<%= sign_in_url %>",
        afterSignUpUrl: "<%= root_url %>",
      });
    }

    if (window.Clerk && window.Clerk.loaded) {
      if (Clerk.user) { window.location.href = "<%= root_url %>"; return; }
      mountSignUp();
    } else {
      window.addEventListener("clerk:loaded", function () {
        if (Clerk.user) { window.location.href = "<%= root_url %>"; return; }
        mountSignUp();
      });
    }
  })();
</script>
