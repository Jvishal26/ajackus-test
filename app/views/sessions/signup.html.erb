<h1>Sign up</h1>

<div id="clerk-sign-up"></div>

<script>
  (function() {
    function mount() {
      var el = document.getElementById("clerk-sign-up");
      if (!el) return;
      window.Clerk.mountSignUp(el, { afterSignUpUrl: "<%= events_url %>" });
    }

    if (window.Clerk) {
      mount();
    } else {
      window.addEventListener("clerk:loaded", mount, { once: true });
    }
  })();
</script>
