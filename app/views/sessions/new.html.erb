<h1>Sign in</h1>

<div id="clerk-sign-in"></div>

<script>
  (function() {
    function mount() {
      var el = document.getElementById("clerk-sign-in");
      if (!el) return;
      window.Clerk.mountSignIn(el, { afterSignInUrl: "<%= events_url %>" });
    }

    if (window.Clerk) {
      mount();
    } else {
      window.addEventListener("clerk:loaded", mount, { once: true });
    }
  })();
</script>
